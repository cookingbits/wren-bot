# ====================================================================
# Wallet Tracker Bot — environment variables
# Copy this file to `.env` and fill in your own values.
# Never commit your real .env to Git.
# ====================================================================

# --- Telegram ---
# Get this from @BotFather on Telegram (see README step 1)
TELEGRAM_BOT_TOKEN=123456789:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# --- Helius (Solana data provider) ---
# Free tier API key from https://www.helius.dev (see README step 2)
HELIUS_API_KEY=your-helius-api-key-here

# --- Payments ---
# A Solana wallet address you OWN — this is where user payments land.
# Create a new wallet in Phantom, copy the public address here.
# NEVER put your private key or seed phrase anywhere in this file.
TREASURY_WALLET_ADDRESS=YourSolanaWalletPublicAddressHere

# Monthly subscription price in USDC (e.g., 9.99)
SUBSCRIPTION_PRICE_USDC=9.99

# --- Tiers ---
# How many wallets a free user can track
FREE_TIER_WALLET_LIMIT=2
# How many wallets a paid user can track
PAID_TIER_WALLET_LIMIT=50

# --- Polling intervals (seconds) ---
# How often to check for new transactions on tracked wallets
WALLET_POLL_INTERVAL=60
# How often to check for new incoming payments on the treasury wallet
PAYMENT_POLL_INTERVAL=30

# --- Admin ---
# Your personal Telegram user ID (for admin commands / debugging)
# Get it by messaging @userinfobot
ADMIN_TELEGRAM_ID=123456789

# --- Database ---
# SQLite file path (leave as default for most cases)
DATABASE_PATH=data/bot.db
